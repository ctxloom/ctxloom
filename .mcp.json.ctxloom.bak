{
  "mcpServers": {
    "ctxloom": {
      "command": "/usr/bin/ctxloom",
      "args": [
        "mcp"
      ],
      "cwd": "${CLAUDE_PROJECT_DIR}",
      "_ctxloom": "ctxloom-auto"
    },
    "scm": {
      "command": "/home/babbitt/go/bin/scm",
      "args": [
        "mcp"
      ],
      "cwd": "${CLAUDE_PROJECT_DIR}"
    }
  }
}