{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "$id": "https://ctxloom.dev/schemas/config.json",
  "title": "ctxloom Configuration",
  "description": "Schema for ctxloom config.yaml files",
  "type": "object",
  "properties": {
    "version": {
      "type": ["string", "number"],
      "description": "Schema version for the config format",
      "examples": ["1.0", 1.0]
    },
    "llm": {
      "type": "object",
      "description": "Language model plugin configuration",
      "properties": {
        "plugin_paths": {
          "type": "array",
          "description": "Paths to search for external plugin binaries",
          "items": {
            "type": "string"
          },
          "examples": [["/home/user/.ctxloom/plugins", ".ctxloom/plugins"]]
        },
        "plugins": {
          "type": "object",
          "description": "Plugin configurations keyed by name",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "model": {
                "type": "string",
                "description": "Default model to use with this plugin",
                "examples": ["opus", "sonnet", "gpt-4"]
              },
              "binary_path": {
                "type": "string",
                "description": "Path to the plugin binary (optional, uses PATH if empty)"
              },
              "args": {
                "type": "array",
                "description": "Command line arguments to pass to the plugin",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "description": "Environment variables to set for the plugin",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "editor": {
      "type": "object",
      "description": "Editor configuration for fragment/prompt editing",
      "properties": {
        "command": {
          "type": "string",
          "description": "Editor command to use",
          "examples": ["vim", "nano", "code"]
        },
        "args": {
          "type": "array",
          "description": "Additional arguments for the editor",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "description": "Default settings",
      "properties": {
        "profiles": {
          "type": "array",
          "description": "Default profiles to load when no profile is specified",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "llm_plugin": {
          "type": "string",
          "description": "Default LLM plugin to use (e.g., 'claude-code', 'gemini')"
        },
        "llm_model": {
          "type": "string",
          "description": "Default LLM model to use within the plugin (e.g., 'opus', 'sonnet', 'haiku')"
        },
        "use_distilled": {
          "type": "boolean",
          "description": "Whether to prefer distilled versions of fragments/prompts (default: true)"
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "$ref": "#/$defs/hooksConfig",
      "description": "Hooks configuration applied globally"
    },
    "mcp": {
      "type": "object",
      "description": "MCP (Model Context Protocol) server configuration",
      "properties": {
        "auto_register_ctxloom": {
          "type": "boolean",
          "description": "Whether to automatically register ctxloom's own MCP server (default: true)"
        },
        "servers": {
          "type": "object",
          "description": "Unified MCP server configurations (applied to all backends)",
          "additionalProperties": {
            "$ref": "#/$defs/mcpServer"
          }
        },
        "plugins": {
          "type": "object",
          "description": "Backend-specific MCP server configurations (keyed by backend name)",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/mcpServer"
            }
          }
        }
      },
      "additionalProperties": false
    },
    "memory": {
      "type": "object",
      "description": "Session memory configuration (experimental)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable session memory logging",
          "default": false
        },
        "logging": {
          "type": "object",
          "description": "Logging configuration for session memory",
          "properties": {
            "tool_result_max": {
              "type": "integer",
              "description": "Maximum characters to log from tool results",
              "default": 500
            },
            "exclude_tools": {
              "type": "array",
              "description": "Tools to exclude from logging",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "compaction": {
          "type": "object",
          "description": "Compaction settings for session memory",
          "properties": {
            "plugin": {
              "type": "string",
              "description": "LLM plugin to use for distillation",
              "default": "claude-code",
              "examples": ["claude-code", "gemini"]
            },
            "model": {
              "type": "string",
              "description": "Model to use within the plugin for distillation",
              "default": "haiku",
              "examples": ["haiku", "sonnet", "flash"]
            },
            "chunk_size": {
              "type": "integer",
              "description": "Target token count per chunk",
              "default": 8000
            }
          },
          "additionalProperties": false
        },
        "vectors": {
          "type": "object",
          "description": "Vector database configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether to enable vector search",
              "default": false
            },
            "model_path": {
              "type": "string",
              "description": "Path to the ONNX embedding model"
            }
          },
          "additionalProperties": false
        },
        "load_on_start": {
          "type": "boolean",
          "description": "Whether to load recent memory on session start",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "profiles": {
      "type": "object",
      "description": "Named collections of context fragments and variables",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "default": {
            "type": "boolean",
            "description": "Whether this profile is a default profile (automatically loaded when no explicit fragments/tags/profile specified)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of this profile"
          },
          "parents": {
            "type": "array",
            "description": "Parent profiles to inherit from (processed depth-first)",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "tags": {
            "type": "array",
            "description": "Fragment tags to include (fragments with matching tags are added)",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "fragments": {
            "type": "array",
            "description": "Explicit fragment paths to include",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "variables": {
            "type": "object",
            "description": "Variable values for template substitution in fragments",
            "additionalProperties": {
              "type": "string"
            }
          },
          "hooks": {
            "$ref": "#/$defs/hooksConfig",
            "description": "Hooks configuration for this profile (inherited from parents)"
          },
          "exclude_fragments": {
            "type": "array",
            "description": "Fragment names to exclude from this profile (filtered after inheritance)",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "exclude_prompts": {
            "type": "array",
            "description": "Prompt names to exclude from this profile (filtered after inheritance)",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "exclude_mcp": {
            "type": "array",
            "description": "MCP server names to exclude from this profile (filtered after inheritance)",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "mcpServer": {
      "type": "object",
      "description": "MCP server configuration",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "string",
          "description": "Command to run the MCP server",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "description": "Arguments for the server command",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "description": "Environment variables for the server",
          "additionalProperties": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "description": "Human-readable notes about the server (not sent to AI)"
        },
        "installation": {
          "type": "string",
          "description": "Setup/installation instructions (not sent to AI)"
        }
      },
      "additionalProperties": false
    },
    "hook": {
      "type": "object",
      "description": "A hook definition",
      "properties": {
        "matcher": {
          "type": "string",
          "description": "Regex pattern to filter when hook fires (by tool name, event source, etc.)"
        },
        "command": {
          "type": "string",
          "description": "Shell command to execute",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "description": "Hook handler type",
          "enum": ["command", "prompt", "agent"],
          "default": "command"
        },
        "prompt": {
          "type": "string",
          "description": "Prompt text for prompt/agent hook types"
        },
        "timeout": {
          "type": "integer",
          "description": "Execution timeout in seconds",
          "minimum": 1,
          "default": 30
        },
        "async": {
          "type": "boolean",
          "description": "Run hook in background (command hooks only)",
          "default": false
        }
      },
      "additionalProperties": true
    },
    "hookArray": {
      "type": "array",
      "description": "Array of hooks for an event",
      "items": {
        "$ref": "#/$defs/hook"
      }
    },
    "unifiedHooks": {
      "type": "object",
      "description": "Unified hook events (translated to backend-specific format)",
      "properties": {
        "pre_tool": {
          "$ref": "#/$defs/hookArray",
          "description": "Before tool execution"
        },
        "post_tool": {
          "$ref": "#/$defs/hookArray",
          "description": "After tool execution"
        },
        "session_start": {
          "$ref": "#/$defs/hookArray",
          "description": "When session starts"
        },
        "session_end": {
          "$ref": "#/$defs/hookArray",
          "description": "When session ends"
        },
        "pre_shell": {
          "$ref": "#/$defs/hookArray",
          "description": "Before shell command execution"
        },
        "post_file_edit": {
          "$ref": "#/$defs/hookArray",
          "description": "After file edit"
        }
      },
      "additionalProperties": false
    },
    "hooksConfig": {
      "type": "object",
      "description": "Hooks configuration",
      "properties": {
        "unified": {
          "$ref": "#/$defs/unifiedHooks",
          "description": "Unified hooks (translated per-backend)"
        },
        "plugins": {
          "type": "object",
          "description": "Backend-specific passthrough hooks (keyed by plugin name)",
          "additionalProperties": {
            "type": "object",
            "description": "Backend-native hook events",
            "additionalProperties": {
              "$ref": "#/$defs/hookArray"
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
